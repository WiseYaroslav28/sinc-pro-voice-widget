{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-app",
  "version": "3.5.1",
  "identifier": "com.sincpro.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SINC PRO",
        "url": "index.html",
        "width": 960,
        "height": 600,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "shadow": true
      },
      {
        "label": "capsule",
        "title": "SINC Orb",
        "url": "capsule.html",
        "width": 340,
        "height": 260,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "shadow": false,
        "skipTaskbar": true
      },
      {
        "label": "widget",
        "title": "SINC PRO - Виджет",
        "url": "widget.html",
        "width": 560,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "shadow": false,
        "skipTaskbar": true
      },
      {
        "label": "ocr",
        "title": "SINC PRO - Переводчик",
        "url": "ocr.html",
        "width": 600,
        "height": 400,
        "fullscreen": false,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "mic",
        "title": "SINC PRO - Микрофон",
        "url": "mic.html",
        "width": 120,
        "height": 48,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "result",
        "title": "SINC PRO - Результат",
        "url": "result.html",
        "width": 400,
        "height": 260,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "shadow": true,
        "skipTaskbar": true
      },
      {
        "label": "prompt",
        "title": "SINC PRO - Свой промпт",
        "url": "prompt.html",
        "width": 450,
        "height": 220,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "shadow": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": ["style-src"],
      "csp": "default-src 'self' ipc: http://ipc.localhost https://ipc.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost data:; media-src 'self' asset: http://asset.localhost https://asset.localhost data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/WiseYaroslav28/sinc-pro-voice-widget/master/docs/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFGMzZGODgzREYwQTQ0NEMKUldSTVJBcmZnL2cySHhrbUIvSUlmRlp3aHRnTGpNUEZiWVJOckV4eW15ZU9UVXNJNEVoVHorZkcK"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}